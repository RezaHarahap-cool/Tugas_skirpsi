// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  siswa
  guru
  admin
  kepala_sekolah 
}

enum GenderLengkap {
  Laki_laki
  Perempuan
}

enum GenderSingkat {
  Wanita
  Pria
}

// ==========================================
// 1. TABEL USERS (AKUN PUSAT)
// ==========================================

model User {
  id_users   String   @id @default(uuid()) @db.Uuid
  username   String   @unique @db.VarChar(50)
  password   String   @db.VarChar(255)
  email      String   @unique @db.VarChar(100)
  role       Role
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)

  // Pendefinisian Relasi One-to-One ke tabel profil
  admin          AdminProfile?
  guru           GuruProfile?
  siswa          SiswaProfile?
  kepala_sekolah KepalaSekolahProfile?

  @@map("users")
}

// ==========================================
// 2. TABEL ADMIN
// ==========================================

model AdminProfile {
  id_admin      String        @id @default(uuid()) @db.Uuid
  users_id      String        @unique @db.Uuid
  nama_admin    String        @db.VarChar(50)
  jenis_kelamin GenderLengkap
  no_hp         String        @db.VarChar(20)
  foto          String?       @db.VarChar(255) // Optional (?) karena foto bisa saja kosong di awal

  // Konfigurasi Foreign Key
  user User @relation(fields: [users_id], references: [id_users], onDelete: Cascade)

  @@map("admin_profiles")
}

// ==========================================
// 3. TABEL GURU
// ==========================================

model GuruProfile {
  id_guru              String        @id @default(uuid()) @db.Uuid
  users_id             String        @unique @db.Uuid
  nama_guru            String        @db.VarChar(50)
  tgl_lahir            DateTime      @db.Timestamp(0)
  gender               GenderSingkat
  agama                String        @db.VarChar(50)
  pendidikan_tertinggi String        @db.VarChar(50)
  no_hp                String        @db.VarChar(20)
  foto                 String?       @db.VarChar(255)
  mapel_id             Int           // Disiapkan untuk relasi ke tabel mapel nanti

  user User @relation(fields: [users_id], references: [id_users], onDelete: Cascade)

  @@map("guru_profiles")
}

// ==========================================
// 4. TABEL SISWA
// ==========================================

model SiswaProfile {
  id_siswa         String        @id @default(uuid()) @db.Uuid
  users_id         String        @unique @db.Uuid
  npsn             BigInt        // Menggunakan BigInt karena INT(14) bisa melebihi batas standar Integer
  nis              BigInt        
  nisn             BigInt        
  foto             String?       @db.VarChar(255)
  nama_siswa       String        @db.VarChar(255)
  gender           GenderSingkat
  tempat_tgl_lahir String        @db.VarChar(55)
  kelas_id         Int           // Disiapkan untuk relasi ke tabel kelas nanti
  nama_ayah        String        @db.VarChar(55)
  pekerjaan_ayah   String        @db.VarChar(55)
  nama_ibu         String        @db.VarChar(55)
  pekerjaan_ibu    String        @db.VarChar(55)
  alamat           String        @db.VarChar(55)
  desa_kelurahan   String        @map("desa/kelurahan") @db.VarChar(55)
  kecamatan        String        @db.VarChar(55)
  kabupaten_kota   String        @map("kabupaten/kota") @db.VarChar(55)
  provinsi         String        @db.VarChar(55)
  no_hp_wali       String        @db.VarChar(55)

  user User @relation(fields: [users_id], references: [id_users], onDelete: Cascade)

  @@map("siswa_profiles")
}

// ==========================================
// 5. TABEL KEPALA SEKOLAH
// ==========================================

model KepalaSekolahProfile {
  id_kepsek            String        @id @default(uuid()) @db.Uuid
  users_id             String        @unique @db.Uuid
  nama_ks              String        @db.VarChar(50)
  tgl_lahir            DateTime      @db.Timestamp(0)
  gender               GenderSingkat
  agama                String        @db.VarChar(50)
  pendidikan_tertinggi String        @db.VarChar(20)
  foto                 String?       @db.VarChar(255)

  user User @relation(fields: [users_id], references: [id_users], onDelete: Cascade)

  @@map("kepala_sekolah_profiles")
}